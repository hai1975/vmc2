# Google Gemini API key (server-side only — used to mint ephemeral Live tokens)
GEMINI_API_KEY=

# Gemini Live model for native audio duplex
# Recommended: gemini-3.1-flash-live-preview
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_MODEL_NL=gemini-2.5-flash-native-audio-preview-12-2025
# Document OCR (Scan button) — gemini-2.0-flash was shut down Jun 2026
GEMINI_VISION_MODEL=gemini-2.5-flash

# Paths (relative to project root)
FORM_DIR=Form
SCHEMA_DIR=schemas
DATA_DIR=data

# Database
DATABASE_URL=sqlite:///./data/vmc.db

# SMTP (optional — for sending PDF on submit; can also configure in app Settings UI)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,capacitor://localhost,http://localhost,https://hai1975.com,https://www.hai1975.com
